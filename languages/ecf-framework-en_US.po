msgid "ecf_generated_css_description"
msgstr "This is the CSS currently generated from your Layrix settings. It updates automatically whenever you save the settings."

msgid "ecf_generated_css_export"
msgstr "Export CSS"

msgid "ecf_generated_css_note"
msgstr "Use this CSS snapshot if you want to preserve the current frontend styling outside the plugin, for example before deactivating Layrix."

msgid "ecf_generated_css_title"
msgstr "Current CSS"

msgid "ecf_generated_css_why_text"
msgstr "Layrix generates important frontend CSS dynamically. If the plugin is deactivated later, these styles disappear even if the classes still exist in the HTML. This field therefore shows the currently generated CSS as a readable snapshot that you can copy or export to keep the current design outside the plugin if needed."

msgid "ecf_generated_css_why_title"
msgstr "Why does this field exist?"

